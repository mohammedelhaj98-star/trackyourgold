generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ItemCategory {
  JEWELRY
  COIN
  BAR
  SCRAP
  OTHER
}

enum SourceType {
  api
  retail_html
}

enum FetchMethod {
  api_json
  html_static
  html_headless
}

enum ScrapingRisk {
  low
  medium
  high
}

enum Confidence {
  high
  medium
  low
}

enum IngestStatus {
  ok
  partial
  failed
}

enum ValuationMode {
  intrinsic
  retail
  sell_est
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique
  username      String?        @unique
  passwordHash  String         @map("password_hash")
  language      String         @default("en")
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  refreshTokens RefreshToken[]
  vaults        Vault[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Market {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String   @unique
  nameEn          String   @map("name_en")
  nameAr          String   @map("name_ar")
  defaultCurrency String   @default("QAR") @map("default_currency")
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("markets")
}

model Vault {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String           @map("owner_id") @db.Uuid
  name            String
  defaultCurrency String           @default("QAR") @map("default_currency")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items           VaultItem[]
  valuationCache  ValuationCache[]

  @@index([ownerId])
  @@map("vaults")
}

model VaultItem {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaultId               String       @map("vault_id") @db.Uuid
  itemName              String       @map("item_name")
  category              ItemCategory
  purityKarat           Int          @map("purity_karat")
  grossWeightG          Decimal      @map("gross_weight_g") @db.Decimal(12, 4)
  stoneWeightG          Decimal      @default(0) @map("stone_weight_g") @db.Decimal(12, 4)
  netGoldWeightG        Decimal      @default(0) @map("net_gold_weight_g") @db.Decimal(12, 4)
  purchaseDate          DateTime     @map("purchase_date") @db.Date
  purchaseTotalPriceQar Decimal      @map("purchase_total_price_qar") @db.Decimal(14, 2)
  makingChargesQar      Decimal      @default(0) @map("making_charges_qar") @db.Decimal(14, 2)
  vatQar                Decimal      @default(0) @map("vat_qar") @db.Decimal(14, 2)
  purchaseStoreName     String?      @map("purchase_store_name")
  purchaseLocation      String?      @map("purchase_location")
  purchaseNotes         String?      @map("purchase_notes")
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  vault                 Vault        @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId])
  @@map("vault_items")
}

model PriceSource {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String             @unique
  name              String
  sourceType        SourceType         @map("source_type")
  host              String
  path              String
  fetchMethod       FetchMethod        @map("fetch_method")
  enabled           Boolean            @default(true)
  scrapingRisk      ScrapingRisk       @map("scraping_risk")
  confidence        Confidence
  updateHintMinutes Int                @default(10) @map("update_hint_minutes")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  health            SourceHealth?
  normalizedPrices  PriceNormalized[]
  rawSnapshots      PriceSnapshotRaw[]
  robotsCache       SourceRobotsCache[]

  @@map("price_sources")
}

model SourceRobotsCache {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId  String      @map("source_id") @db.Uuid
  fetchedAt DateTime    @default(now()) @map("fetched_at") @db.Timestamptz(6)
  expiresAt DateTime    @map("expires_at") @db.Timestamptz(6)
  robotsTxt String      @map("robots_txt")
  allowAll  Boolean     @default(false) @map("allow_all")
  parsedOk  Boolean     @default(false) @map("parsed_ok")
  notes     String?
  source    PriceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, expiresAt])
  @@map("source_robots_cache")
}

model RawSnapshotBlob {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  encoding    String
  contentType String?  @map("content_type")
  payload     Bytes
  sha256      String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  snapshots   PriceSnapshotRaw[]

  @@map("raw_snapshot_blobs")
}

model PriceSnapshotRaw {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId    String          @map("source_id") @db.Uuid
  blobId      String          @map("blob_id") @db.Uuid
  fetchedAt   DateTime        @default(now()) @map("fetched_at") @db.Timestamptz(6)
  httpStatus  Int             @map("http_status")
  contentType String?         @map("content_type")
  parseOk     Boolean         @default(false) @map("parse_ok")
  parseError  String?         @map("parse_error")
  source      PriceSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  blob        RawSnapshotBlob @relation(fields: [blobId], references: [id], onDelete: Cascade)

  @@index([sourceId, fetchedAt(sort: Desc)])
  @@map("price_snapshots_raw")
}

model PriceNormalized {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId        String      @map("source_id") @db.Uuid
  asOf            DateTime    @map("as_of") @db.Timestamptz(6)
  currency        String      @default("QAR")
  unit            String      @default("per_gram")
  price24kPerGram Decimal     @map("price_24k_per_gram") @db.Decimal(14, 4)
  price23kPerGram Decimal?    @map("price_23k_per_gram") @db.Decimal(14, 4)
  price22kPerGram Decimal     @map("price_22k_per_gram") @db.Decimal(14, 4)
  price21kPerGram Decimal?    @map("price_21k_per_gram") @db.Decimal(14, 4)
  price18kPerGram Decimal?    @map("price_18k_per_gram") @db.Decimal(14, 4)
  price14kPerGram Decimal?    @map("price_14k_per_gram") @db.Decimal(14, 4)
  price12kPerGram Decimal?    @map("price_12k_per_gram") @db.Decimal(14, 4)
  price10kPerGram Decimal?    @map("price_10k_per_gram") @db.Decimal(14, 4)
  price9kPerGram  Decimal?    @map("price_9k_per_gram") @db.Decimal(14, 4)
  price8kPerGram  Decimal?    @map("price_8k_per_gram") @db.Decimal(14, 4)
  meta            Json        @default("{}")
  source          PriceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, asOf(sort: Desc)])
  @@map("prices_normalized")
}

model IngestRun {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runStartedAt  DateTime     @default(now()) @map("run_started_at") @db.Timestamptz(6)
  runFinishedAt DateTime?    @map("run_finished_at") @db.Timestamptz(6)
  status        IngestStatus
  summary       Json         @default("{}")

  @@map("ingest_runs")
}

model SourceHealth {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId            String      @unique @map("source_id") @db.Uuid
  lastSuccessAt       DateTime?   @map("last_success_at") @db.Timestamptz(6)
  lastFailureAt       DateTime?   @map("last_failure_at") @db.Timestamptz(6)
  consecutiveFailures Int         @default(0) @map("consecutive_failures")
  lastError           String?     @map("last_error")
  lastHttpStatus      Int?        @map("last_http_status")
  lastParsedAsOf      DateTime?   @map("last_parsed_as_of") @db.Timestamptz(6)
  staleAfterMinutes   Int         @default(60) @map("stale_after_minutes")
  source              PriceSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@map("source_health")
}

model ValuationCache {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vaultId    String        @map("vault_id") @db.Uuid
  mode       ValuationMode
  computedAt DateTime      @default(now()) @map("computed_at") @db.Timestamptz(6)
  expiresAt  DateTime      @map("expires_at") @db.Timestamptz(6)
  asOf       DateTime      @map("as_of") @db.Timestamptz(6)
  payload    Json
  vault      Vault         @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, mode])
  @@map("valuation_cache")
}

model SeoMetadata {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  canonical   String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  contentPages ContentPage[]
  blogArticles BlogArticle[]

  @@map("seo_metadata")
}

model ContentPage {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String       @unique
  title         String
  templateKey   String       @map("template_key")
  body          Json         @default("{}")
  seoMetadataId String?      @map("seo_metadata_id") @db.Uuid
  published     Boolean      @default(true)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  seoMetadata   SeoMetadata? @relation(fields: [seoMetadataId], references: [id], onDelete: SetNull)

  @@map("content_pages")
}

model BlogArticle {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String       @unique
  title         String
  excerpt       String?
  body          Json         @default("{}")
  seoMetadataId String?      @map("seo_metadata_id") @db.Uuid
  published     Boolean      @default(false)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  seoMetadata   SeoMetadata? @relation(fields: [seoMetadataId], references: [id], onDelete: SetNull)

  @@map("blog_articles")
}

model Faq {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionEn String   @map("question_en")
  questionAr String   @map("question_ar")
  answerEn   String   @map("answer_en")
  answerAr   String   @map("answer_ar")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("faqs")
}

model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("settings")
}
